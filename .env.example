# Copy this file to .env and fill in values before running docker compose up.

# WHO 2006 z-score Excel files (6 files must be present in this folder inside the container)
WHO_ZSCORE_DIR=/app/data/zscore

# PostgreSQL credentials — used by both the postgres service and the api service
POSTGRES_USER=smartdqc
POSTGRES_PASSWORD=smartdqc
POSTGRES_DB=smartdqc

# DATABASE_URL is constructed automatically in docker-compose.yml from the vars above.
# Set this manually only if connecting to an external Postgres instance.
# DATABASE_URL=postgresql://smartdqc:smartdqc@localhost:5432/smartdqc

# Ollama model to use — any valid tag from https://ollama.com/library.
# Default Qwen3.5 4B Q4_K_M (~2.7GB) — bilingual JSON output, fits 8GB GPU.
# Alternatives:
#   qwen3.5:4b-q8_0    (~4.5GB, near-full-precision, higher quality)
#   qwen3.5:4b          (Ollama default quant, typically Q4_K_M)
# Pulled automatically on first boot; the host needs internet that first time.
OLLAMA_MODEL=qwen3.5:4b-q4_K_M

# Qwen3.5 is a hybrid-reasoning model. think:false makes it write the answer
# straight to `response` (not the `thinking` field) — faster and more reliable
# for our structured-JSON prompts. Set to "true" only to re-enable reasoning.
OLLAMA_THINK=false

# Ollama service URL (internal Docker network — do not change for local deployment)
OLLAMA_BASE_URL=http://ollama:11434

# ── Authentication — REQUIRED, change both before any deployment ─────────────
# Generate JWT_SECRET with: openssl rand -hex 32
JWT_SECRET=change-me-before-production
ADMIN_SEED_PASSWORD=change-me-before-production
