# Copy this file to .env and fill in values before running docker compose up.

# WHO 2006 z-score Excel files (6 files must be present in this folder inside the container)
WHO_ZSCORE_DIR=/app/data/zscore

# PostgreSQL credentials — used by both the postgres service and the api service
POSTGRES_USER=smartdqc
POSTGRES_PASSWORD=smartdqc
POSTGRES_DB=smartdqc

# DATABASE_URL is constructed automatically in docker-compose.yml from the vars above.
# Set this manually only if connecting to an external Postgres instance.
# DATABASE_URL=postgresql://smartdqc:smartdqc@localhost:5432/smartdqc

# Ollama model to use — any valid tag from https://ollama.com/library.
# Default Gemma 4 e4b-it-qat — larger and higher-quality than e2b; needs more
# VRAM, so confirm it fits the deployment GPU.
OLLAMA_MODEL=gemma4:e4b-it-qat

# Gemma 4 e4b is non-reasoning. think:false writes the answer straight to
# `response` (not the `thinking` field) — faster and more reliable for our
# structured-JSON prompts. OLLAMA_THINK has no effect on Gemma 4.
OLLAMA_THINK=false

# Keep the model resident (no post-idle unload/CPU fallback); use a duration
# like "30m" only on a shared GPU.
OLLAMA_KEEP_ALIVE=-1

# Cap context so the model + KV cache fit in 8GB VRAM (Gemma 4 defaults to a
# 128K context that preallocates a multi-GB KV cache).
OLLAMA_CONTEXT_LENGTH=8192

# Ollama service URL.
#   Bundled single-host (default — `docker compose up -d`): leave as the
#   internal Docker service name below; the bundled `ollama` service uses the
#   host GPU.
#   Split deployment (LLM on a separate GPU host, e.g. a DGX): point this at the
#   GPU host, e.g. OLLAMA_BASE_URL=http://10.0.0.5:11434, and start only the
#   non-LLM services:  docker compose up -d postgres api frontend
#   The GPU host must bind Ollama on 0.0.0.0 and allow the port through its
#   firewall.
OLLAMA_BASE_URL=http://ollama:11434

# ── Authentication (legacy — not required for current X-User name-based auth) ──
# SmartDQC no longer uses password login. Users identify by name via the X-User
# header. These vars are retained for backwards compatibility only.
JWT_SECRET=change-me-before-production
ADMIN_SEED_PASSWORD=change-me-before-production
